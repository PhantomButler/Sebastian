# LLM API keys are managed via the Settings page (stored in DB, encrypted).
# JWT signing key (secret.key) is auto-generated by the setup wizard.

SEBASTIAN_OWNER_NAME=Eric
SEBASTIAN_DATA_DIR=~/.sebastian
SEBASTIAN_SANDBOX_ENABLED=false

SEBASTIAN_GATEWAY_HOST=0.0.0.0
SEBASTIAN_GATEWAY_PORT=8823

SEBASTIAN_BROWSER_HEADLESS=true
SEBASTIAN_BROWSER_VIEWPORT=1280x900
SEBASTIAN_BROWSER_TIMEOUT_MS=30000
SEBASTIAN_BROWSER_DNS_MODE=auto
SEBASTIAN_BROWSER_DOH_ENDPOINT=https://dns.alidns.com/resolve
SEBASTIAN_BROWSER_DOH_TIMEOUT_MS=5000
# Optional: forward safe browser traffic through a local HTTP proxy.
# Example: SEBASTIAN_BROWSER_UPSTREAM_PROXY=http://127.0.0.1:7890
SEBASTIAN_BROWSER_UPSTREAM_PROXY=

# OPENAI_API_KEY=sk-...           # reserved, not currently used
# SEBASTIAN_FCM_KEY=...           # Phase 3 (voice push)
